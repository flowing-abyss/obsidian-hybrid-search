{
  "name": "obsidian-hybrid-search",
  "version": "0.4.0",
  "type": "module",
  "bin": {
    "obsidian-hybrid-search": "./dist/src/cli.js",
    "obsidian-hybrid-search-mcp": "./dist/src/server.js"
  },
  "scripts": {
    "prepare": "husky",
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "test": "tsx test/run-tests.ts",
    "test:integration": "tsx test/integration.test.ts",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flowing-abyss/obsidian-hybrid-search"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "@xenova/transformers": "^2.17.0",
    "better-sqlite3": "latest",
    "chokidar": "^4.0.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "sqlite-vec": "latest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.1.9"
  }
}
